---
import { formatPostLabel } from '../../lib/format.ts';

interface Props {
  size: 'big' | 'small';
  number: number;
  category: string;
  question: string;
  attribution?: string;
}

const { size, number, category, question, attribution } = Astro.props;
const label = formatPostLabel(number, category);
---

<div class:list={['thumb', 'thumb-question', `is-${size}`]} aria-hidden="true">
  <div class="label">{label}</div>
  <div class="quote-block">
    <span class="quote-mark open" aria-hidden="true">&ldquo;</span>
    <p class="question">{question}</p>
    <span class="quote-mark close" aria-hidden="true">&rdquo;</span>
  </div>
  {attribution && <div class="attribution">{attribution}</div>}
</div>

<style>
  .thumb-question {
    background: var(--green);
    color: #f0ecdf;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    padding: clamp(20px, 7cqi, 48px);
  }

  .label {
    font-family: var(--font-meta);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--terra-soft);
    font-size: clamp(10px, 2.4cqi, 12px);
  }

  .quote-block {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .question {
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.018em;
    color: #f0ecdf;
    margin: 0;
    max-width: 80%;
    text-wrap: balance;
    word-break: keep-all;
    font-size: clamp(16px, 6cqi, 30px);
  }

  .quote-mark {
    position: absolute;
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--terra-soft);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    font-size: clamp(44px, 18cqi, 110px);
  }

  .quote-mark.open {
    top: -0.1em;
    left: 0;
  }

  .quote-mark.close {
    bottom: -0.45em;
    right: 0;
  }

  .attribution {
    color: rgba(240, 236, 223, 0.72);
    text-align: right;
    line-height: 1.4;
    font-size: clamp(10px, 2.6cqi, 13px);
  }
</style>
