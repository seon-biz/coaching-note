---
import type { CollectionEntry } from 'astro:content';
import ThumbnailKeyword from './thumbnails/ThumbnailKeyword.astro';
import ThumbnailFragment from './thumbnails/ThumbnailFragment.astro';
import ThumbnailNumeral from './thumbnails/ThumbnailNumeral.astro';
import ThumbnailQuestion from './thumbnails/ThumbnailQuestion.astro';
import ThumbnailList from './thumbnails/ThumbnailList.astro';
import { formatNumericDate, formatPostLabel } from '../lib/format.ts';

interface Props {
  post: CollectionEntry<'posts'>;
  size: 'big' | 'small';
}

const { post, size } = Astro.props;
const { title, number, category, date, excerpt, readingTime, thumbnail } = post.data;
const href = `/blog/${String(number).padStart(3, '0')}`;
const dateLabel = formatNumericDate(date);
const numberLabel = formatPostLabel(number, category);
---

<article class:list={['post', `post-${size}`]}>
  <a class="thumb-link" href={href} aria-label={title}>
    {thumbnail.pattern === 'keyword' && (
      <ThumbnailKeyword
        size={size}
        number={number}
        category={category}
        keyword={thumbnail.keyword}
      />
    )}
    {thumbnail.pattern === 'fragment' && (
      <ThumbnailFragment
        size={size}
        number={number}
        category={category}
        fragment={thumbnail.fragment}
        highlight={thumbnail.highlight}
      />
    )}
    {thumbnail.pattern === 'numeral' && (
      <ThumbnailNumeral
        size={size}
        number={number}
        category={category}
        num={thumbnail.number}
        unit={thumbnail.unit}
        quote={thumbnail.quote}
      />
    )}
    {thumbnail.pattern === 'question' && (
      <ThumbnailQuestion
        size={size}
        number={number}
        category={category}
        question={thumbnail.question}
        attribution={thumbnail.attribution}
      />
    )}
    {thumbnail.pattern === 'list' && (
      <ThumbnailList
        size={size}
        number={number}
        category={category}
        items={thumbnail.items}
        highlight={thumbnail.highlight}
        footer={thumbnail.footer}
      />
    )}
  </a>

  <div class="meta-row">
    <span class="meta">{dateLabel}</span>
    <span class="meta terra">· {numberLabel}</span>
    {size === 'big' && readingTime && <span class="meta">{readingTime}</span>}
  </div>

  {size === 'big' ? (
    <h2 class="title"><a href={href}>{title}</a></h2>
  ) : (
    <h3 class="title"><a href={href}>{title}</a></h3>
  )}

  <p class="excerpt">{excerpt}</p>

  {size === 'big' && (
    <a class="read-more" href={href}>
      계속 읽기 <span class="arrow">→</span>
    </a>
  )}
</article>

<style>
  .post {
    display: block;
  }

  .thumb-link {
    display: block;
    color: inherit;
  }

  .meta-row {
    display: flex;
    gap: 24px;
  }

  .title a {
    color: var(--ink);
    transition: color 0.15s;
  }

  .title a:hover {
    color: var(--terra);
  }

  /* ---- Big card ---- */
  .post-big .thumb-link {
    margin-bottom: 32px;
  }
  .post-big .meta-row {
    margin-bottom: 14px;
  }
  .post-big .title {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    letter-spacing: -0.022em;
    line-height: 1.25;
    margin: 0 0 18px;
    text-wrap: balance;
  }
  .post-big .excerpt {
    font-size: 16px;
    line-height: 1.8;
    color: var(--ink);
    margin: 0 0 22px;
    max-width: 680px;
    text-wrap: pretty;
  }

  .read-more {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--terra);
    transition: color 0.15s;
    display: inline-block;
  }
  .read-more:hover {
    color: var(--ink);
  }
  .read-more .arrow {
    display: inline-block;
    margin-left: 6px;
    transition: transform 0.2s;
  }
  .read-more:hover .arrow {
    transform: translateX(3px);
  }

  /* ---- Small card ---- */
  .post-small .thumb-link {
    margin-bottom: 22px;
  }
  .post-small .meta-row {
    gap: 18px;
    margin-bottom: 10px;
  }
  .post-small .title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.018em;
    line-height: 1.3;
    margin: 0 0 12px;
    text-wrap: balance;
  }
  .post-small .excerpt {
    font-size: 15px;
    line-height: 1.7;
    color: var(--mute);
    margin: 0;
  }
</style>
