---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpiralMark from '../components/SpiralMark.astro';

// 폼 제출은 /api/contact (Cloudflare Pages Functions + Resend) 로 보냅니다.
// 핸들러: functions/api/contact.ts

const offerings = [
  {
    num: '01 · 1:1 코칭',
    title: '1:1 코칭',
    body: '회사 대표 한 분과 함께합니다. 컴퓨터 활용 능력에 맞춰 진도를 조절합니다.',
  },
  {
    num: '02 · 상세페이지',
    title: '상세페이지 기획·디자인 그룹',
    body: 'AI로 기획하고 Claude Code로 디자인합니다. 템플릿을 만들어 다른 상품도 직접 작업할 수 있게 합니다.',
  },
  {
    num: '03 · SEO',
    title: 'SEO · AI SEO 그룹',
    body: 'Cafe24 자사몰 SEO, 서치 콘솔, GA4 분석을 다룹니다.',
  },
  {
    num: '04 · 웹사이트',
    title: '웹사이트 제작',
    body: 'Claude로 기획하고, Claude Design으로 디자인하고, Claude Code로 만듭니다. 외주 없이 직접 만들고 운영할 수 있게 됩니다.',
  },
];
---

<BaseLayout title="상담신청" description="1:1 코칭과 그룹 코칭 신청. 주 1회 줌으로 만납니다.">
  <script is:inline>
    if (new URLSearchParams(location.search).get('sent') === 'true') {
      document.documentElement.dataset.consultState = 'sent';
    }
  </script>

  <!-- ================== FORM STATE ================== -->
  <div id="state-form">
    <section class="hero page">
      <span class="meta-label terra">CONSULTATION</span>
      <h1>상담신청</h1>
    </section>

    <section class="offerings page" aria-label="코칭 안내">
      {offerings.map((o) => (
        <div class="item">
          <div class="num">{o.num}</div>
          <div class="copy">
            <h3>{o.title}</h3>
            <p>{o.body}</p>
          </div>
        </div>
      ))}
      <p class="closing">모두 주 1회 줌으로 진행합니다.</p>
    </section>

    <section class="form-section form-shell">
      <p class="lead">짧게 적어 보내주세요.</p>
      <p class="sub">사업체나 상황을 한 줄로 두어도 좋습니다. 만나서 더 묻겠습니다.</p>

      <form class="consult" novalidate>
        <div class="form-error" role="alert" hidden></div>

        <div class="field-row">
          <div class="field">
            <label for="name">이름</label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="contact">연락처 <span class="opt">이메일 또는 휴대폰</span></label>
            <input type="text" id="contact" name="contact" autocomplete="email" required />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="interest">관심 있는 코칭</label>
            <div class="select-wrap">
              <select id="interest" name="interest" required>
                <option value="" selected>선택해주세요</option>
                <option value="1:1 코칭">1:1 코칭</option>
                <option value="상세페이지 기획·디자인 그룹">상세페이지 기획·디자인 그룹</option>
                <option value="SEO · AI SEO 그룹">SEO · AI SEO 그룹</option>
                <option value="웹사이트 제작">웹사이트 제작</option>
                <option value="아직 정하지 못했습니다">아직 정하지 못했습니다</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label for="company">사업체명</label>
            <input type="text" id="company" name="company" autocomplete="organization" placeholder="선택사항" />
          </div>
        </div>

        <div class="field">
          <label for="message">문의 내용</label>
          <textarea
            id="message"
            name="message"
            placeholder="지금 어떤 자리에 계신지, 어떤 부분이 막혀 있는지 — 편하게 적어주세요."
          ></textarea>
        </div>

        <div class="actions">
          <button type="submit" class="btn-primary">
            신청하기
            <span aria-hidden="true">→</span>
          </button>
          <p class="reply-note">보내주시면 빠르면 당일, 늦어도 2~3일 안에 답장 드립니다.</p>
        </div>
      </form>
    </section>
  </div>

  <!-- ================== SENT STATE ================== -->
  <div id="state-sent">
    <section class="submitted form-shell">
      <span class="meta-label terra">SENT</span>
      <h2>✓ 신청이 접수되었습니다.</h2>
      <p>영업일 기준 2~3일 안에 답장 드립니다.</p>
      <a class="home-link" href="/">
        메인으로
        <span aria-hidden="true">→</span>
      </a>
      <div class="mark-wrap">
        <SpiralMark size={48} color="var(--terra)" />
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('form.consult');
  if (form) {
    const errorEl = form.querySelector<HTMLDivElement>('.form-error');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const originalButtonHtml = button?.innerHTML ?? '';

    const showError = (html: string) => {
      if (!errorEl) return;
      errorEl.innerHTML = html;
      errorEl.hidden = false;
    };
    const clearError = () => {
      if (errorEl) errorEl.hidden = true;
    };
    const setSending = (sending: boolean) => {
      if (!button) return;
      button.disabled = sending;
      button.innerHTML = sending ? '전송 중...' : originalButtonHtml;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearError();

      const data = new FormData(form);
      const body = {
        name: String(data.get('name') ?? ''),
        contact: String(data.get('contact') ?? ''),
        coaching: String(data.get('interest') ?? ''),
        business: String(data.get('company') ?? ''),
        message: String(data.get('message') ?? ''),
      };

      setSending(true);

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          document.documentElement.dataset.consultState = 'sent';
          return;
        }

        if (res.status === 400) {
          showError('입력 내용을 다시 확인해 주세요.');
          setSending(false);
          return;
        }

        showError(
          '전송이 지연되고 있습니다.<br>' +
            '직접 연락 부탁드립니다: ' +
            '<a href="mailto:cobaltblue872@gmail.com">cobaltblue872@gmail.com</a>'
        );
        setSending(false);
      } catch (err) {
        console.error(err);
        showError(
          '전송이 지연되고 있습니다.<br>' +
            '직접 연락 부탁드립니다: ' +
            '<a href="mailto:cobaltblue872@gmail.com">cobaltblue872@gmail.com</a>'
        );
        setSending(false);
      }
    });
  }
</script>

<style>
  /* state toggle via root dataset (set by inline script above) */
  :root:not([data-consult-state="sent"]) #state-sent { display: none; }
  :root[data-consult-state="sent"] #state-form { display: none; }

  /* ---- PAGE SHELLS ---- */
  .page {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .form-shell {
    max-width: var(--form-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .meta-label {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .meta-label.terra { color: var(--terra); }

  /* ---- HERO ---- */
  .hero {
    padding: 160px var(--gutter) 96px;
  }
  .hero .meta-label {
    margin-bottom: 24px;
    display: block;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.026em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }

  /* ---- COACHING LIST ---- */
  .offerings {
    padding-bottom: 128px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 128px;
  }
  .offerings .item {
    padding: 36px 0;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    align-items: flex-start;
  }
  .offerings .item:last-of-type {
    border-bottom: 1px solid var(--rule);
  }
  .offerings .num {
    font-family: var(--font-meta);
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--terra);
    padding-top: 6px;
  }
  .offerings .copy h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.018em;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .offerings .copy p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--ink);
    margin: 0;
    max-width: 520px;
    text-wrap: pretty;
    word-break: keep-all;
  }
  .offerings .closing {
    margin-top: 36px;
    font-size: 15px;
    color: var(--mute);
    padding-left: 248px;
  }

  /* ---- FORM ---- */
  .form-section {
    padding-bottom: 128px;
  }
  .form-section .lead {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.014em;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 8px;
    text-wrap: balance;
  }
  .form-section .sub {
    font-size: 15px;
    color: var(--mute);
    margin: 0 0 64px;
    line-height: 1.7;
  }

  form.consult {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .form-error {
    background: rgba(185, 28, 28, 0.06);
    border-left: 2px solid #b91c1c;
    color: #b91c1c;
    padding: 14px 18px;
    font-size: 14px;
    line-height: 1.7;
    word-break: keep-all;
  }
  .form-error a {
    color: inherit;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .field label {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .field label .opt {
    color: var(--mute-2);
    font-size: 10px;
    margin-left: 6px;
    letter-spacing: 0.18em;
  }
  .field input[type="text"],
  .field input[type="email"],
  .field input[type="tel"],
  .field select,
  .field textarea {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule);
    padding: 10px 0;
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--ink);
    line-height: 1.5;
    outline: none;
    transition: border-color 0.15s;
    border-radius: 0;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--mute-2);
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-bottom-color: var(--terra);
  }
  .field textarea {
    min-height: 140px;
    resize: vertical;
    padding-top: 14px;
  }
  .field .select-wrap {
    position: relative;
  }
  .field select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 28px;
    cursor: pointer;
  }
  .field .select-wrap::after {
    content: "";
    position: absolute;
    right: 6px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-right: 1.5px solid var(--mute);
    border-bottom: 1.5px solid var(--mute);
    transform: translateY(-75%) rotate(45deg);
    pointer-events: none;
  }

  /* CTA */
  .actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    margin-top: 16px;
  }
  .btn-primary {
    background: var(--terra);
    color: #fff;
    padding: 16px 36px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover {
    background: #a8522e;
  }
  .btn-primary:active {
    transform: translateY(1px);
  }
  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }
  .reply-note {
    font-size: 14px;
    color: var(--mute);
    line-height: 1.6;
    margin: 0;
  }

  /* ---- SUBMITTED STATE ---- */
  .submitted {
    padding: 160px var(--gutter) 192px;
    text-align: left;
  }
  .submitted .meta-label {
    margin-bottom: 32px;
    display: block;
  }
  .submitted h2 {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.026em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 24px;
  }
  .submitted p {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--mute);
    margin: 0 0 64px;
    max-width: 480px;
    text-wrap: pretty;
  }
  .submitted .home-link {
    font-family: var(--font-meta);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--terra);
    border-bottom: 1px solid var(--terra);
    padding-bottom: 3px;
    transition: color 0.15s, border-color 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .submitted .home-link:hover {
    color: var(--ink);
    border-color: var(--ink);
  }
  .submitted .mark-wrap {
    margin-top: 64px;
  }

  /* ---- Mobile ---- */
  @media (max-width: 720px) {
    .hero { padding: 64px var(--gutter) 48px; }
    .hero h1 { font-size: 36px; }
    .offerings { padding-bottom: 64px; margin-bottom: 64px; }
    .offerings .item { grid-template-columns: 1fr; gap: 14px; padding: 28px 0; }
    .offerings .closing { padding-left: 0; margin-top: 28px; }
    .field-row { grid-template-columns: 1fr; gap: 32px; }
    .submitted { padding: 80px var(--gutter) 96px; }
    .submitted h2 { font-size: 34px; }
  }
</style>
