---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const [bigPost, ...rest] = posts;
const smallPosts = rest.slice(0, 2);
---

<BaseLayout>
  <!-- ================== HERO ================== -->
  <section class="hero">
    <div class="container">
      <div class="eyebrow">
        <div class="name-ko">서정옥</div>
        <div class="name-en">Online Business Coach · 8 Years</div>
      </div>
      <p class="statement">
        낯섦을 반복하면 <span class="terra">익숙한 것</span>이 된다는 것을 알게 되었습니다.
      </p>
    </div>
  </section>

  <!-- ================== RECENT NOTES ================== -->
  <section class="notes">
    <div class="container">
      <div class="section-head">
        <div class="title">최근 글</div>
        <div class="meta">RECENT NOTES</div>
      </div>

      {bigPost && (
        <div class="big-wrap">
          <PostCard post={bigPost} size="big" />
        </div>
      )}

      {smallPosts.length > 0 && (
        <div class="posts-row">
          {smallPosts.map((post) => (
            <PostCard post={post} size="small" />
          ))}
        </div>
      )}

      <div class="archive-link">
        <a class="read-more" href="/blog">지금까지 쓴 글 더 보기 <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- ================== TRUST BANNER ================== -->
  <section class="trust">
    <div class="inner">
      <div class="eyebrow">ONE BY ONE · SINCE 2018</div>
      <p>
        가르치지 않습니다.<br />
        그 사람의 속도로, 옆에서 같이 걷습니다.
      </p>
    </div>
  </section>

  <!-- ================== COACHING ================== -->
  <section class="coaching">
    <div class="container">
      <div class="eyebrow meta">COACHING</div>
      <h2 class="section-title">코칭</h2>
      <p class="body">
        1:1 코칭과 상세페이지·쇼핑몰·SEO 그룹 코칭을 진행합니다.
        모두 주 1회 줌으로 만나, 그 한 주의 결정과 흐름을 함께 짚습니다.
      </p>
      <a class="cta" href="/consult">자세한 안내 <span class="arrow">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- HERO ---- */
  .hero {
    padding: 160px 0 144px;
  }
  .hero .eyebrow {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 48px;
  }
  .hero .name-ko {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--ink);
  }
  .hero .name-en {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--mute);
    text-transform: uppercase;
  }
  .hero .statement {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 500;
    letter-spacing: -0.024em;
    line-height: 1.55;
    color: var(--ink);
    max-width: 720px;
    margin: 0;
    text-wrap: pretty;
  }
  .hero .statement .terra {
    color: var(--terra);
  }

  /* ---- RECENT NOTES ---- */
  .notes {
    padding-top: 0;
    padding-bottom: var(--section-gap);
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 24px;
    margin-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }
  .section-head .title {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .big-wrap {
    margin-bottom: 96px;
  }

  .posts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 64px;
  }

  .archive-link {
    display: flex;
    justify-content: flex-end;
  }

  .read-more {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--terra);
    transition: color 0.15s;
    display: inline-block;
  }
  .read-more:hover {
    color: var(--ink);
  }
  .read-more .arrow {
    display: inline-block;
    margin-left: 6px;
    transition: transform 0.2s;
  }
  .read-more:hover .arrow {
    transform: translateX(3px);
  }

  /* ---- TRUST BANNER ---- */
  .trust {
    background: var(--green);
    color: #f0ecdf;
    padding: 160px var(--gutter);
  }
  .trust .inner {
    max-width: var(--container);
    margin: 0 auto;
  }
  .trust p {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.55;
    margin: 0;
    max-width: 780px;
    text-wrap: pretty;
    word-break: keep-all;
  }
  .trust .nums {
    font-weight: 700;
    color: #fff;
  }
  .trust .eyebrow {
    font-family: var(--font-meta);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--terra-soft);
    margin-bottom: 32px;
  }

  /* ---- COACHING ---- */
  .coaching {
    padding: var(--section-gap) 0;
  }
  .coaching .eyebrow {
    margin-bottom: 28px;
  }
  .coaching .section-title {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.026em;
    margin: 0 0 36px;
    line-height: 1;
    color: var(--ink);
  }
  .coaching .body {
    font-size: 18px;
    line-height: 1.8;
    color: var(--ink);
    margin: 0 0 40px;
    max-width: 640px;
  }
  .coaching .cta {
    font-family: var(--font-meta);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--terra);
    border-bottom: 1px solid var(--terra);
    padding-bottom: 4px;
    transition: color 0.15s, border-color 0.15s;
  }
  .coaching .cta:hover {
    color: var(--ink);
    border-color: var(--ink);
  }
  .coaching .cta .arrow {
    display: inline-block;
    margin-left: 8px;
    transition: transform 0.2s;
  }
  .coaching .cta:hover .arrow {
    transform: translateX(3px);
  }

  /* ---- Mobile ---- */
  @media (max-width: 760px) {
    .hero {
      padding: 96px 0 80px;
    }
    .hero .statement {
      font-size: 28px;
    }
    .notes {
      padding-bottom: var(--section-gap-mobile);
    }
    .posts-row {
      grid-template-columns: 1fr;
      gap: 80px;
    }
    .big-wrap {
      margin-bottom: 80px;
    }
    .trust {
      padding: 96px var(--gutter);
    }
    .trust p {
      font-size: 26px;
    }
    .coaching {
      padding: var(--section-gap-mobile) 0;
    }
    .coaching .section-title {
      font-size: 36px;
    }
  }
</style>
